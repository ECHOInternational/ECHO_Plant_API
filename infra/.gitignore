# Terraform working directories and downloaded plugins
**/.terraform/
# Terraform provider binaries inside lock dirs
**/.terraform.lock.hcl
# Local state files (bootstrap uses local state — gitignore to avoid accidental commits)
# Comment out the line below if you want to track bootstrap state in git
**/terraform.tfstate
**/terraform.tfstate.backup
# Crash logs
crash.log
crash.*.log
# Sensitive variable files
*.tfvars.json
# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# CLI config file
.terraformrc
terraform.rc
